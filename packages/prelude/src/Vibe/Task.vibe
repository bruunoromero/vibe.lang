module Vibe.Task exposing (Task, fromPromise)

import Vibe.Basics exposing (..)
import Vibe.Result as Result exposing (Result(..))
import Vibe.Promise as Promise exposing (Promise)

type Task x a 
    = Task (Promise (Result x a))

fromPromise : Promise a -> Task x a
fromPromise promise =
    promise 
    |> Promise.map Ok 
    |> Promise.catch Err 
    |> Task

map : (a -> b) -> Task x a -> Task x b
map f (Task promise) =
    promise 
    |> Promise.map (Result.map f)
    |> Task
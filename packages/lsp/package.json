    "test": "bun test",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@vibe/config": "workspace:*",
    "@vibe/formatter": "workspace:*",
    "@vibe/module-resolver": "workspace:*",
    "@vibe/parser": "workspace:*",
    "@vibe/semantics": "workspace:*",
    "@vibe/syntax": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.0.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.4"
  }
}

{
  "name": "@vibe/lsp",
  "version": "0.0.0",
  "type": "module",
  "module": "src/server.ts",
  "scripts": {
    "build": "bun build src/server.ts --target node --outfile dist/server.js",
    "dev": "bun src/server.ts --transport stdio",
